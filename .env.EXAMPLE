# Trading System - Environment Variables
# Copy to .env and fill in your values.

# Alpaca API (required)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=

# LLM provider (optional - platform handles this)
# OPENAI_API_KEY=
